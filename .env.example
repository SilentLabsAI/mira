# MIRA local config
# Copy to .env and fill your own values.
# Never commit .env or real service keys.

OPENAI_API_KEY=your_openai_api_key_here

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

CHAT_MODEL=gpt-5-mini
FAST_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-large
DOCUMENT_EMBEDDING_MODEL=text-embedding-3-small

# Optional local demo IDs. Replace with app-owned UUIDs in production.
MIRA_USER_ID=11111111-1111-1111-1111-111111111111
MIRA_THREAD_ID=22222222-2222-2222-2222-222222222222

# Optional local eval path. Provide your own dataset if you run evals.
LOCOMO_DATA_PATH=./data/locomo10.json
